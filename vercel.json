{
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/img/optimized/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/urbanum-logo.jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
